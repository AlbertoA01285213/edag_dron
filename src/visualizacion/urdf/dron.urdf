<?xml version="1.0"?>
<robot name="dron">
    <gazebo>
        <static>false</static>
    </gazebo>
<!-- 
    <link name="world_link"/>

    <joint name="world_to_base" type="fixed">
        <parent link="world_link"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint> -->

    <link name="base_link"/>

    <link name="dron_link">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="package://visualizacion/models/dron/meshes/djimini4pro.obj" scale=" 2 2 2"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/> <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="base_to_dron" type="fixed">
        <parent link="base_link"/>
        <child link="dron_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="propela_1">
        <visual>
            <origin rpy="0 0 0" xyz="-0.155 0.068 -0.003"/>
            <geometry>
                <mesh filename="package://visualizacion/models/propela/meshes/propela.obj" scale=" 2 2 2"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.01"/> <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <link name="propela_2">
        <visual>
            <origin rpy="0 0 0" xyz="-0.155 0.068 -0.003"/>
            <geometry>
                <mesh filename="package://visualizacion/models/propela/meshes/propela.obj" scale=" 2 2 2"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.01"/> <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <link name="propela_3">
        <visual>
            <origin rpy="0 0 0" xyz="-0.155 0.114 -0.04"/>
            <geometry>
                <mesh filename="package://visualizacion/models/propela/meshes/propela.obj" scale=" 2 2 2"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.01"/> <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <link name="propela_4">
        <visual>
            <origin rpy="0 0 0" xyz="-0.155 0.114 -0.04"/>
            <geometry>
                <mesh filename="package://visualizacion/models/propela/meshes/propela.obj" scale=" 2 2 2"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.01"/> <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <link name="camera_link">
        <visual>
            <origin rpy="0.0 0.0 0.0" xyz="-0.65 0.1 -0.17"/>
            <geometry>
                <box size="0.05 0.05 0.05"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="dron_to_camera" type="fixed">
        <parent link="dron_link"/>
        <child link="camera_link"/>
        <origin xyz="1.0 0 0.5" rpy="0 0 0"/> 
    </joint>

    <joint name="dron_to_propela1" type="continuous">
        <parent link="dron_link"/>
        <child link="propela_1"/>
        <origin xyz="0.155 -0.135 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="dron_to_propela2" type="continuous">
        <parent link="dron_link"/>
        <child link="propela_2"/>
        <origin xyz="-0.155 0.135 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="dron_to_propela3" type="continuous">
        <parent link="dron_link"/>
        <child link="propela_3"/>
        <origin xyz="0.155 0.135 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
    </joint>

    <joint name="dron_to_propela4" type="continuous">
        <parent link="dron_link"/>
        <child link="propela_4"/>
        <origin xyz="-0.155 -0.135 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
    </joint>

    <gazebo reference="camera_link">
        <sensor name="camera" type="camera">
            <pose>0 0 0 0 0 0</pose>
            <always_on>1</always_on>
            <update_rate>30</update_rate>
            <visualize>true</visualize>
            <topic>camera/left</topic>
            <camera>
                <horizontal_fov>1.92</horizontal_fov>
                <image>
                    <width>1920</width>
                    <height>1080</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>100</far>
                </clip>
            </camera>
        </sensor>
    </gazebo>

    <gazebo>
        <plugin
            filename="ignition-gazebo-pose-publisher-system"
            name="ignition::gazebo::systems::PosePublisher">
            <publish_link_pose>false</publish_link_pose>
            <publish_model_pose>true</publish_model_pose> <publish_nested_model_pose>false</publish_nested_model_pose>
            <use_pose_vector_msg>false</use_pose_vector_msg>
            <update_frequency>50</update_frequency> 
        </plugin>
        <plugin
            filename="ignition-gazebo-multicopter-control-system"
            name="ignition::gazebo::systems::MulticopterVelocityControl">
            <robotNamespace>dron</robotNamespace>
            <commandSubTopic>cmd_vel</commandSubTopic>
            <enableControl>true</enableControl>
            <comLinkName>base_link</comLinkName>

            <velocityGain>2.0 2.0 2.0</velocityGain>
            <attitudeGain>2.0 2.0 2.0</attitudeGain>
            <angularRateGain>0.5 0.5 0.5</angularRateGain>
    
            <rotorConfiguration>
                <rotor>
                    <jointName>dron_to_propela1</jointName>
                    <forceConstant>8.54858e-06</forceConstant>
                    <momentConstant>0.016</momentConstant>
                    <direction>1</direction> 
                </rotor>
                <rotor>
                    <jointName>dron_to_propela2</jointName>
                    <forceConstant>8.54858e-06</forceConstant>
                    <momentConstant>0.016</momentConstant>
                    <direction>1</direction>
                </rotor>
                <rotor>
                    <jointName>dron_to_propela3</jointName>
                    <forceConstant>8.54858e-06</forceConstant>
                    <momentConstant>0.016</momentConstant>
                    <direction>-1</direction>
                </rotor>
                <rotor>
                    <jointName>dron_to_propela4</jointName>
                    <forceConstant>8.54858e-06</forceConstant>
                    <momentConstant>0.016</momentConstant>
                    <direction>-1</direction>
                </rotor>
            </rotorConfiguration>
        </plugin>
    </gazebo>
</robot>



