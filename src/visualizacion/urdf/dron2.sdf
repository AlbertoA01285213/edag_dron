<?xml version="1.0"?>
<sdf version="1.8">
    <model name="dron">
        <pose>0 0 0 0 0 0</pose>
        <link name="base_link">
            <inertial>
                <pose>0 0.01 0 0 0 0</pose>
                <mass>0.25</mass>
                <inertia>
                    <ixx>0.000016572</ixx>
                    <ixy>0.00</ixy>
                    <ixz>0.00</ixz>
                    <iyy>0.000016656</iyy>
                    <iyz>0.00000</iyz>
                    <izz>0.000029262</izz>
                </inertia>
            </inertial>
            <collision name="base_link_collision">
                <pose>0 0 0 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.1 0.1 0.3</size>
                    </box>
                </geometry>
            </collision>
            <visual name="base_link_visual">
                <pose>0 -0.15 0 0 0 0</pose>
                <geometry>
                    <mesh>
                        <uri>model://dron/meshes/djimini4pro.obj</uri>
                        <scale>2 2 2</scale>
                    </mesh>
                </geometry>
            </visual>
            <sensor name="imu_sensor" type="imu">
                <always_on>1</always_on>
                <update_rate>250</update_rate>
                <!-- <visualize>true</visualize> -->
                <!-- <topic>/imu</topic> -->
                <!-- <topic>/world/mundo/model/dron/link/base_link/sensor/imu_sensor/imu</topic> -->
            </sensor>
            <sensor name="magnetometer_sensor" type="magnetometer">
                <always_on>1</always_on>
                <update_rate>100</update_rate>
                <!-- <visualize>true</visualize>
                <topic>/mag</topic> -->
            </sensor>   
            <sensor name="air_pressure_sensor" type="air_pressure">
                <always_on>1</always_on>
                <update_rate>50</update_rate>
                <!-- <visualize>true</visualize>
                <topic>/air_pressure</topic> -->
            </sensor>
            <sensor name="navsat_sensor" type="navsat">
                <always_on>1</always_on>
                <update_rate>10</update_rate>
                <!-- <visualize>true</visualize> -->
                <!-- <topic>/gps</topic> -->
            </sensor>
        </link>

        <link name="dron/m1_prop">
            <pose> 0.15 -0.15 0 0 0 0</pose>
            <inertial>
                <pose>0 0 0 0 0 0</pose>
                <mass>0.001</mass>
                <inertia>
                    <ixx>0.00000014</ixx>
                    <iyy>0.00001169</iyy>
                    <izz>0.00001176</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="dron/m1_visual">
                <pose>-0.147 -0.067 -0.002 0 0 0</pose>
                <geometry>
                    <mesh>
                        <uri>model://propela/meshes/propela.obj</uri>
                        <scale>2 2 2</scale>
                    </mesh>
                </geometry>
            </visual>
        </link>

        <link name="dron/m2_prop">
            <pose> -0.15 -0.15 0 0 0 0</pose>
            <inertial>
                <pose>0 0 0 0 0 0</pose>
                <mass>0.001</mass>
                <inertia>
                    <ixx>0.00000014</ixx>
                    <iyy>0.00001169</iyy>
                    <izz>0.00001176</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="dron/m2_visual">
                <pose>-0.159 -0.067 -0.002 0 0 0</pose>
                <geometry>
                    <mesh>
                        <uri>model://propela/meshes/propela.obj</uri>
                        <scale>2 2 2</scale>
                    </mesh>
                </geometry>
            </visual>
        </link>

        <link name="dron/m3_prop">
            <pose> -0.15 0.15 0 0 0 0</pose>
            <inertial>
                <pose>0 0 0 0 0 0</pose>
                <mass>0.001</mass>
                <inertia>
                    <ixx>0.00000014</ixx>
                    <iyy>0.00001169</iyy>
                    <izz>0.00001176</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="dron/m3_visual">
                <pose>-0.159 -0.052 -0.04 0 0 0</pose>
                <geometry>
                    <mesh>
                        <uri>model://propela/meshes/propela.obj</uri>
                        <scale>2 2 2</scale>
                        </mesh>
                </geometry>
            </visual>
        </link>

        <link name="dron/m4_prop">
            <pose> 0.15 0.15 0 0 0 0</pose>
            <inertial>
                <pose>0 0 0 0 0 0</pose>
                <mass>0.001</mass>
                <inertia>
                    <ixx>0.00000014</ixx>
                    <iyy>0.00001169</iyy>
                    <izz>0.00001176</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="dron/m4_visual">
                <pose>-0.15 -0.053 -0.04 0 0 0</pose>
                <geometry>
                    <mesh>
                        <uri>model://propela/meshes/propela.obj</uri>
                        <scale>2 2 2</scale>
                    </mesh>
                </geometry>
            </visual>
        </link>

        <joint name="dron/m1_joint" type="revolute">
            <child>dron/m1_prop</child>
            <parent>base_link</parent>
            <axis>
                <xyz>0 0 1</xyz>
                <limit>
                    <lower>-1e16</lower>
                    <upper>1e16</upper>
                </limit>
                <dynamics>
                    <spring_reference>0</spring_reference>
                    <spring_stiffness>0</spring_stiffness>
                </dynamics>
                <use_parent_model_frame>1</use_parent_model_frame>
            </axis>
        </joint>

        <joint name="dron/m2_joint" type="revolute">
            <child>dron/m2_prop</child>
            <parent>base_link</parent>
            <axis>
                <xyz>0 0 1</xyz>
                <limit>
                    <lower>-1e16</lower>
                    <upper>1e16</upper>
                </limit>
                <dynamics>
                    <spring_reference>0</spring_reference>
                    <spring_stiffness>0</spring_stiffness>
                </dynamics>
                <use_parent_model_frame>1</use_parent_model_frame>
            </axis>
        </joint>

        <joint name="dron/m3_joint" type="revolute">
            <child>dron/m3_prop</child>
            <parent>base_link</parent>
            <axis>
                <xyz>0 0 1</xyz>
                <limit>
                    <lower>-1e16</lower>
                    <upper>1e16</upper>
                </limit>
                <dynamics>
                    <spring_reference>0</spring_reference>
                    <spring_stiffness>0</spring_stiffness>
                </dynamics>
                <use_parent_model_frame>1</use_parent_model_frame>
            </axis>
        </joint>

        <joint name="dron/m4_joint" type="revolute">
            <child>dron/m4_prop</child>
            <parent>base_link</parent>
            <axis>
                <xyz>0 0 1</xyz>
                <limit>
                    <lower>-1e16</lower>
                    <upper>1e16</upper>
                </limit>
                <dynamics>
                    <spring_reference>0</spring_reference>
                    <spring_stiffness>0</spring_stiffness>
                </dynamics>
                <use_parent_model_frame>1</use_parent_model_frame>
            </axis>
        </joint>

    <plugin
        filename="ignition-gazebo-multicopter-motor-model-system"
        name="ignition::gazebo::systems::MulticopterMotorModel">
        <robotNamespace>dron</robotNamespace>
        <jointName>dron/m1_joint</jointName>
        <linkName>dron/m1_prop</linkName>
        <turningDirection>ccw</turningDirection>
        <timeConstantUp>0.0125</timeConstantUp>
        <timeConstantDown>0.025</timeConstantDown>
        <maxRotVelocity>1000</maxRotVelocity>
        <motorConstant>8.5e-08</motorConstant>
        <momentConstant>2.4e-04</momentConstant>
        <commandSubTopic>actuators</commandSubTopic>
        <motorNumber>0</motorNumber>
        <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
        <rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
        <motorSpeedPubTopic>motor_speed/0</motorSpeedPubTopic>
        <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
        <motorType>velocity</motorType>
    </plugin>
    <plugin
        filename="ignition-gazebo-multicopter-motor-model-system"
        name="ignition::gazebo::systems::MulticopterMotorModel">
        <robotNamespace>dron</robotNamespace>
        <jointName>dron/m2_joint</jointName>
        <linkName>dron/m2_prop</linkName>
        <turningDirection>cw</turningDirection>
        <timeConstantUp>0.0125</timeConstantUp>
        <timeConstantDown>0.025</timeConstantDown>
        <maxRotVelocity>1000</maxRotVelocity>
        <motorConstant>8.5e-08</motorConstant>
        <momentConstant>2.4e-04</momentConstant>
        <commandSubTopic>actuators</commandSubTopic>
        <motorNumber>1</motorNumber>
        <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
        <rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
        <motorSpeedPubTopic>motor_speed/1</motorSpeedPubTopic>
        <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
        <motorType>velocity</motorType>
    </plugin>
    <plugin
        filename="ignition-gazebo-multicopter-motor-model-system"
        name="ignition::gazebo::systems::MulticopterMotorModel">
        <robotNamespace>dron</robotNamespace>
        <jointName>dron/m3_joint</jointName>
        <linkName>dron/m3_prop</linkName>
        <turningDirection>ccw</turningDirection>
        <timeConstantUp>0.0125</timeConstantUp>
        <timeConstantDown>0.025</timeConstantDown>
        <maxRotVelocity>1000</maxRotVelocity>
        <motorConstant>8.5e-08</motorConstant>
        <momentConstant>2.4e-04</momentConstant>
        <commandSubTopic>actuators</commandSubTopic>
        <motorNumber>2</motorNumber>
        <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
        <rollingMomentCoefficient>0.0000001</rollingMomentCoefficient>
        <motorSpeedPubTopic>motor_speed/2</motorSpeedPubTopic>
        <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
        <motorType>velocity</motorType>
    </plugin>
    <plugin
        filename="ignition-gazebo-multicopter-motor-model-system"
        name="ignition::gazebo::systems::MulticopterMotorModel">
        <robotNamespace>dron</robotNamespace>
        <jointName>dron/m4_joint</jointName>
        <linkName>dron/m4_prop</linkName>
        <turningDirection>cw</turningDirection>
        <timeConstantUp>0.0125</timeConstantUp>
        <timeConstantDown>0.025</timeConstantDown>
        <maxRotVelocity>1000</maxRotVelocity>
        <motorConstant>8.5e-08</motorConstant>
        <momentConstant>2.4e-04</momentConstant>
        <commandSubTopic>actuators</commandSubTopic>
        <motorNumber>3</motorNumber>
        <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
        <rollingMomentCoefficient>0.000001</rollingMomentCoefficient>
        <motorSpeedPubTopic>motor_speed/3</motorSpeedPubTopic>
        <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
        <motorType>velocity</motorType>
    </plugin> 
    <plugin
        filename="ignition-gazebo-odometry-publisher-system"
        name="ignition::gazebo::systems::OdometryPublisher">
        <dimensions>3</dimensions>
    </plugin>
      <!-- Moving Forward-->
        <plugin filename="libignition-gazebo-triggered-publisher-system.so"
        name="ignition::gazebo::systems::TriggeredPublisher">
            <input type="ignition.msgs.Int32" topic="/keyboard/keypress">
            <match field="data">16777235</match>
            </input>
            <output type="ignition.msgs.Twist" topic="/cmd_vel">
            linear: {x: 0.05}, angular: {z: 0.0}
            </output>
        </plugin>
    </model>
</sdf>
    


